{
  "name": "quality-gate-action",
  "version": "1.0.0",
  "description": "GitHub Action for Quality Gate based on SARIF files",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "package": "ncc build dist/index.js --out dist --minify",
    "clean": "rm -rf dist",
    "prepare": "npm run build && npm run package"
  },
  "keywords": [
    "github-action",
    "sarif",
    "security",
    "quality-gate",
    "codeql",
    "trivy",
    "snyk",
    "semgrep"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/QualityGate.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/QualityGate/issues"
  },
  "homepage": "https://github.com/your-org/QualityGate#readme",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "fast-glob": "^3.3.3",
    "minimatch": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}