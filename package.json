{
  "name": "qualitygate",
  "version": "1.0.0",
  "description": "Universal SARIF security quality gate for CodeQL, Snyk, Trivy, Semgrep, Checkov, Grype, and more.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "package": "npm run build && ncc build lib/index.js --out dist --minify --source-map",
    "clean": "rm -rf dist lib",
    "all": "npm run build && npm test && npm run package"
  },
  "keywords": [
    "github-action",
    "sarif",
    "security",
    "quality-gate",
    "codeql",
    "trivy",
    "snyk",
    "semgrep"
  ],
  "author": "QualityGate maintainers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/narendra486/qualitygate.git"
  },
  "bugs": {
    "url": "https://github.com/narendra486/qualitygate/issues"
  },
  "homepage": "https://github.com/narendra486/qualitygate#readme",
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/github": "6.0.1",
    "fast-glob": "3.3.3",
    "minimatch": "9.0.9"
  },
  "overrides": {
    "undici": "6.25.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.6.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vercel/ncc": "0.38.4",
    "eslint": "10.3.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
