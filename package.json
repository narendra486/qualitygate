{
  "name": "qualitygate",
  "version": "1.0.0",
  "description": "Enterprise-grade GitHub Action for SARIF-based security quality gates supporting CodeQL, Snyk, Trivy, Semgrep, Checkov, Grype, and other scanners.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "package": "npm run build && ncc build lib/index.js --out dist --minify --source-map",
    "clean": "rm -rf dist lib",
    "all": "npm run build && npm test && npm run package"
  },
  "keywords": [
    "github-action",
    "sarif",
    "security",
    "quality-gate",
    "codeql",
    "trivy",
    "snyk",
    "semgrep"
  ],
  "author": "QualityGate maintainers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/narendra486/qualitygate.git"
  },
  "bugs": {
    "url": "https://github.com/narendra486/qualitygate/issues"
  },
  "homepage": "https://github.com/narendra486/qualitygate#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "fast-glob": "^3.3.3",
    "minimatch": "^9.0.3"
  },
  "overrides": {
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
